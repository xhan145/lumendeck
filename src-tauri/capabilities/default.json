{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the LumenDeck main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/lumendeck-bridge", "sidecar": true, "args": ["--port", "8787"] }]
    },
    "updater:default",
    "process:allow-restart",
    "opener:default"
  ]
}
